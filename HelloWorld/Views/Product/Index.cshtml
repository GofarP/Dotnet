@model IEnumerable<HelloWorld.Models.Product>
@{
    ViewData["Title"] = "Daftar Product";
    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
    
    int pageSize = 10; 
    int rowNumber = ((currentPage - 1) * pageSize) + 1;
}

<div class="p-10 w-full bg-slate-50/50 min-h-screen">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-3xl font-bold text-slate-800">Daftar Product</h1>
        <a asp-action="Create" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2.5 rounded-lg font-bold flex items-center gap-2 transition-all shadow-md">
            <span class="text-xl">+</span> Tambah Baru
        </a>
    </div>

    <div class="flex justify-end mb-6">
        <form asp-action="Index" method="get" id="searchForm">
            <div class="relative group">
                <input type="text" 
                       id="searchInput"
                       name="searchString" 
                       value="@ViewData["CurrentFilter"]"
                       placeholder="Ketik untuk mencari..."
                       autocomplete="off"
                       class="w-80 px-4 py-2.5 border border-slate-200 rounded-xl bg-white shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm transition-all" />
                
                @* Tombol Reset (X) *@
                @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
                {
                    <a asp-action="Index" class="absolute right-3 top-2.5 text-slate-400 hover:text-red-500 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                        </svg>
                    </a>
                }
            </div>
        </form>
    </div>

    @* --- TABLE SECTION --- *@
    <div class="bg-white rounded-xl shadow-md border border-slate-100 overflow-hidden">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                    <th class="px-6 py-4 text-[13px] font-bold text-slate-500 uppercase tracking-wider w-16 text-center">NO</th>
                    <th class="px-6 py-4 text-[13px] font-bold text-slate-500 uppercase tracking-wider">NAMA PRODUCT</th>
                    <th class="px-6 py-4 text-[13px] font-bold text-slate-500 uppercase tracking-wider">HARGA & STOK</th>
                    <th class="px-6 py-4 text-[13px] font-bold text-slate-500 uppercase tracking-wider text-center w-40">AKSI</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="px-6 py-12 text-center text-slate-400 italic">
                            Oops! Produk yang kamu cari kosong / tidak ditemukan.
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-slate-50/30 transition-colors">
                        <td class="px-6 py-5 text-slate-500 text-center font-medium">@(rowNumber++)</td>
                        <td class="px-6 py-5 font-bold text-slate-800">@item.Name</td>
                        <td class="px-6 py-5 text-slate-400 text-sm">
                            <span class="text-slate-700 font-semibold">
                                @item.Price.ToString("C0", new System.Globalization.CultureInfo("id-ID"))
                            </span> 
                            <span class="mx-1">|</span> 
                            @item.Stock Unit
                        </td>
                        <td class="px-6 py-5 text-center text-sm font-medium">
                            <div class="flex justify-center items-center gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="text-blue-600 hover:text-blue-800 font-bold transition-colors">Edit</a>
                                <span class="text-slate-200">|</span>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Hapus produk ini?')" class="inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="text-red-500 hover:text-red-700 font-bold transition-colors">Hapus</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* --- PAGINATION SECTION --- *@
    <div class="mt-8 flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-sm text-slate-500 font-medium">
            Halaman <span class="text-slate-800 font-bold">@currentPage</span> dari <span class="text-slate-800 font-bold">@totalPages</span>
        </p>

        <div class="flex items-center bg-white border border-slate-200 rounded-lg shadow-sm overflow-hidden">
            <a asp-action="Index" asp-route-pageNumber="@(currentPage - 1)" asp-route-searchString="@ViewData["CurrentFilter"]"
               class="px-4 py-2 text-sm font-medium text-slate-400 hover:bg-slate-50 border-r border-slate-200 @(currentPage <= 1 ? "pointer-events-none opacity-40" : "")">
                Prev
            </a>

            @for (int i = 1; i <= totalPages; i++)
            {
                <a asp-action="Index" asp-route-pageNumber="@i" asp-route-searchString="@ViewData["CurrentFilter"]"
                   class="px-4 py-2 text-sm font-bold border-r border-slate-200 transition-colors @(i == currentPage ? "bg-blue-600 text-white" : "text-slate-600 hover:bg-slate-50")">
                    @i
                </a>
            }

            <a asp-action="Index" asp-route-pageNumber="@(currentPage + 1)" asp-route-searchString="@ViewData["CurrentFilter"]"
               class="px-4 py-2 text-sm font-medium text-slate-400 hover:bg-slate-50 @(currentPage >= totalPages ? "pointer-events-none opacity-40" : "")">
                Next
            </a>
        </div>
    </div>
</div>

@* --- JAVASCRIPT UNTUK SEARCH ON-TYPE --- *@
<script>
    const searchInput = document.getElementById('searchInput');
    const searchForm = document.getElementById('searchForm');
    let timeout = null;

    // Memastikan kursor otomatis fokus ke input setelah halaman reload
    // Dan kursor berada di akhir teks
    window.onload = () => {
        if (searchInput.value !== "") {
            const val = searchInput.value;
            searchInput.value = '';
            searchInput.value = val;
            searchInput.focus();
        }
    };

    searchInput.addEventListener('input', function () {
        // Batalkan submit sebelumnya jika user masih mengetik
        clearTimeout(timeout);

        // Tunggu 500ms setelah user berhenti mengetik, baru submit form
        timeout = setTimeout(() => {
            searchForm.submit();
        }, 500); 
    });
</script>
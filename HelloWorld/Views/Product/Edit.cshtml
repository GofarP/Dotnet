@model HelloWorld.Models.Product
@{
    ViewData["Title"] = "Edit Produk";
}

<div class="p-8 w-full max-w-2xl mx-auto">
    <a asp-action="Index" class="inline-flex items-center text-sm text-gray-400 hover:text-blue-600 mb-6 transition-colors">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Batal dan Kembali
    </a>

    <div class="bg-white shadow-xl rounded-2xl overflow-hidden border border-gray-100">
        <div class="bg-blue-50/30 px-8 py-6 border-b border-gray-100">
            <h2 class="text-xl font-bold text-gray-800">Edit Informasi Produk</h2>
            <p class="text-xs text-gray-500 mt-1">ID Produk: #@Model.Id</p>
        </div>

        <form asp-action="Edit" method="post" class="p-8">
            <input type="hidden" asp-for="Id" />
            
            <div asp-validation-summary="ModelOnly" class="mb-6 p-4 bg-red-50 text-red-600 text-sm rounded-lg"></div>

            <div class="space-y-6">
                <div>
                    <label asp-for="Name" class="block text-sm font-semibold text-gray-700 mb-2">Nama Produk</label>
                    <input asp-for="Name" class="w-full px-4 py-2.5 bg-white border border-gray-200 rounded-xl focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 outline-none transition-all" />
                    <span asp-validation-for="Name" class="text-red-500 text-xs mt-1"></span>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label asp-for="Price" class="block text-sm font-semibold text-gray-700 mb-2">Harga Jual</label>
                        <input asp-for="Price" type="number" class="w-full px-4 py-2.5 bg-white border border-gray-200 rounded-xl focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 outline-none transition-all" />
                        <span asp-validation-for="Price" class="text-red-500 text-xs mt-1"></span>
                    </div>

                    <div>
                        <label asp-for="Stock" class="block text-sm font-semibold text-gray-700 mb-2">Stok Saat Ini</label>
                        <input asp-for="Stock" type="number" class="w-full px-4 py-2.5 bg-white border border-gray-200 rounded-xl focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 outline-none transition-all" />
                        <span asp-validation-for="Stock" class="text-red-500 text-xs mt-1"></span>
                    </div>
                </div>
            </div>

            <div class="flex items-center justify-end gap-4 mt-10 pt-6 border-t border-gray-100">
                <button type="submit" class="w-full md:w-auto bg-gray-800 hover:bg-black text-white px-10 py-3 rounded-xl font-bold shadow-lg transition-all transform hover:-translate-y-0.5">
                    Perbarui Produk
                </button>
            </div>
        </form>
    </div>
</div>
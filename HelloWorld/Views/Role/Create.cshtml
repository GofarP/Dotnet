@{ ViewData["Title"] = "Tambah Role"; }

<div class="p-8 w-full mx-auto">
    <div class="bg-white shadow-xl rounded-2xl p-8 border border-gray-100">
        <h2 class="text-xl font-bold text-gray-800 mb-6">Buat Role Baru</h2>
        
        <form asp-action="Create" method="post">
            <div class="mb-6">
                <label class="block text-sm font-semibold text-gray-700 mb-2">Nama Role</label>
                <input name="roleName" type="text" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none" placeholder="Contoh: Admin, Manager, Teknisi" required />
            </div>

            <div class="flex items-center justify-end gap-4">
                <a asp-action="Index" class="text-gray-400 hover:text-gray-600 text-sm">Batal</a>
                <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2 rounded-lg font-bold shadow-lg transition-all">
                    Simpan Role
                </button>
            </div>
        </form>
    </div>
</div>
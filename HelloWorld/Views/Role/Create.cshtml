@{ ViewData["Title"] = "Tambah Role"; }

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<div class="p-8 w-full mx-auto">
    <div class="bg-white shadow-xl rounded-2xl p-8 border border-gray-100">
        <h2 class="text-xl font-bold text-gray-800 mb-6">Buat Role Baru</h2>
        
        <form asp-action="Create" method="post">
            <div class="mb-6">
                <label class="block text-sm font-semibold text-gray-700 mb-2">Nama Role</label>
                <input name="roleName" type="text" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none" placeholder="Contoh: Admin, Manager, Teknisi" required />
            </div>

            <div class="mb-6">
                <label class="block text-sm font-semibold text-gray-700 mb-2">Pilih Izin (Permissions)</label>
                <select name="selectedPermissions" class="select2-multiple w-full" multiple="multiple">
                    @if (ViewBag.MasterPermissions != null)
                    {
                        foreach (var p in (IEnumerable<HelloWorld.Models.Permission>)ViewBag.MasterPermissions)
                        {
                            <option value="@p.Name">@p.Name</option>
                        }
                    }
                </select>
                <p class="text-[10px] text-gray-400 mt-1 italic">*Anda bisa memilih lebih dari satu izin untuk role ini.</p>
            </div>

            <div class="flex items-center justify-end gap-4">
                <a asp-action="Index" class="text-gray-400 hover:text-gray-600 text-sm">Batal</a>
                <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2 rounded-lg font-bold shadow-lg transition-all">
                    Simpan Role
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    
    <script>
        $(document).ready(function() {
            $('.select2-multiple').select2({
                placeholder: " Pilih izin akses...",
                allowClear: true,
                width: '100%' // Agar mengikuti lebar container Tailwind
            });
        });
    </script>

    <style>
        .select2-container--default .select2-selection--multiple {
            border-color: #D1D5DB; /* gray-300 */
            border-radius: 0.5rem; /* rounded-lg */
            padding: 2px 8px;
        }
        .select2-container--default.select2-container--focus .select2-selection--multiple {
            border-color: #6366F1; /* indigo-500 */
            ring: 2px;
        }
    </style>
}
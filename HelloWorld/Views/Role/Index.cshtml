@using Microsoft.AspNetCore.Identity
@model IEnumerable<IdentityRole>
@{
    ViewData["Title"] = "Manajemen Role";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int pageSize = 10;
    int rowNo = ((currentPage - 1) * pageSize) + 1;
    string searchString = ViewBag.SearchString ?? "";
}

<div class="p-8">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10 gap-4">
        
        <h2 class="text-4xl font-bold text-gray-800 tracking-tight">Manajemen Role</h2>

        <div class="flex flex-col items-end gap-3">
            
            <a asp-action="Create" class="bg-indigo-600 hover:bg-indigo-700 text-white px-8 py-3 rounded-2xl text-sm font-bold shadow-xl shadow-indigo-100 transition-all">
                + Tambah Role
            </a>

            <form id="searchForm" asp-action="Index" method="get" class="relative">
                <input type="text" id="searchInput" name="searchString" value="@searchString" 
                       placeholder="Cari nama role..." 
                       class="w-72 pl-5 pr-12 py-3 bg-white border border-gray-100 rounded-2xl text-sm shadow-sm focus:ring-2 focus:ring-indigo-500 outline-none transition-all" />
                
                <div class="absolute right-4 top-3.5 text-gray-300">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                </div>
            </form>
        </div>
    </div>

    <div class="bg-white shadow-sm rounded-[2.5rem] overflow-hidden border border-gray-50">
        <table class="min-w-full">
            <thead class="bg-gray-50/30 border-b border-gray-50">
                <tr class="text-gray-400 text-[10px] font-black uppercase tracking-[0.2em]">
                    <th class="px-10 py-6 text-left w-24">No</th>
                    <th class="px-10 py-6 text-left">Nama Role</th>
                    <th class="px-10 py-6 text-right">Aksi</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="3" class="px-10 py-12 text-center text-gray-400 italic">Data tidak ditemukan.</td>
                    </tr>
                }
                @foreach (var role in Model)
                {
                    <tr class="hover:bg-indigo-50/20 transition-colors group">
                        <td class="px-10 py-6 text-gray-400 font-medium">@(rowNo++)</td>
                        <td class="px-10 py-6">
                            <span class="px-4 py-2 bg-indigo-50/50 text-indigo-700 rounded-xl text-xs font-bold tracking-wide">
                                @role.Name
                            </span>
                        </td>
                        <td class="px-10 py-6">
                            <div class="flex justify-end items-center gap-6 text-[11px] font-bold uppercase tracking-widest">
                                <a asp-action="Edit" asp-route-id="@role.Id" class="text-blue-600 hover:text-blue-800 transition-colors">Edit</a>
                                <span class="text-gray-100">|</span>
                                <form asp-action="Delete" asp-route-id="@role.Id" method="post" onsubmit="return confirm('Hapus role ini?')">
                                    <button type="submit" class="text-red-500 hover:text-red-700 transition-colors">Hapus</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (totalPages > 1)
        {
            <div class="bg-gray-50/50 px-10 py-6 border-t border-gray-50 flex items-center justify-between">
                <div class="text-xs text-gray-500 font-medium">Halaman @currentPage dari @totalPages</div>
                <div class="flex gap-2">
                    <a asp-action="Index" asp-route-pageNumber="@(currentPage - 1)" asp-route-searchString="@searchString"
                       class="px-4 py-2 border border-gray-200 rounded-xl text-xs font-bold @(currentPage <= 1 ? "bg-gray-100 text-gray-300 pointer-events-none" : "bg-white text-gray-700 hover:bg-indigo-50")">
                        Prev
                    </a>

                    @for (int p = 1; p <= totalPages; p++)
                    {
                        <a asp-action="Index" asp-route-pageNumber="@p" asp-route-searchString="@searchString"
                           class="px-4 py-2 border rounded-xl text-xs font-bold @(p == currentPage ? "bg-indigo-600 text-white border-indigo-600 shadow-lg shadow-indigo-100" : "bg-white text-gray-700 hover:bg-indigo-50 border-gray-200")">
                            @p
                        </a>
                    }

                    <a asp-action="Index" asp-route-pageNumber="@(currentPage + 1)" asp-route-searchString="@searchString"
                       class="px-4 py-2 border border-gray-200 rounded-xl text-xs font-bold @(currentPage >= totalPages ? "bg-gray-100 text-gray-300 pointer-events-none" : "bg-white text-gray-700 hover:bg-indigo-50")">
                        Next
                    </a>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        const searchInput = document.getElementById('searchInput');
        const searchForm = document.getElementById('searchForm');
        let timeout = null;

        // Auto search pas ngetik (Debounce 500ms)
        searchInput.addEventListener('input', function () {
            clearTimeout(timeout);
            timeout = setTimeout(() => {
                searchForm.submit();
            }, 500);
        });

        // Pertahankan kursor di akhir teks pas reload
        const val = searchInput.value;
        if(val) {
            searchInput.focus();
            searchInput.setSelectionRange(val.length, val.length);
        }
    </script>
}
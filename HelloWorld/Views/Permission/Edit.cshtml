@model HelloWorld.Models.Permission
@{
    ViewData["Title"] = "Edit Permission";
}

<div class="max-w-lg mx-auto mt-10 bg-white p-8 border border-gray-200 rounded-lg shadow-md">
    <h2 class="text-2xl font-bold mb-6 text-gray-800">Edit Permission</h2>
    <form asp-action="Edit">
        <input type="hidden" asp-for="Id" />
        <div class="mb-4">
            <label asp-for="Name" class="block text-gray-700 text-sm font-bold mb-2">Nama Permission</label>
            <input asp-for="Name"
                   class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:ring-2 focus:ring-blue-400"
                   autocomplete="off" />
            <span asp-validation-for="Name" class="text-red-500 text-xs italic mt-1 block"></span>
        </div>

        <div class="mb-6">
            <label asp-for="Description" class="block text-gray-700 text-sm font-bold mb-2">Deskripsi (Opsional)</label>
            <textarea asp-for="Description"
                      class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:ring-2 focus:ring-blue-400"
                      rows="4"></textarea>
            <span asp-validation-for="Description" class="text-red-500 text-xs italic mt-1 block"></span>
        </div>

        <div class="flex items-center justify-between mt-8">
            <button type="submit"
                    class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2 px-6 rounded focus:outline-none focus:shadow-outline transition duration-150">
                Simpan Perubahan
            </button>
            <a asp-action="Index" class="font-medium text-gray-500 hover:text-gray-800 transition duration-150">
                &larr; Batal
            </a>
        </div>

    </form>
</div>
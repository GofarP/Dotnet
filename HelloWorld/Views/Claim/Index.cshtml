@using System.Security.Claims
@model IEnumerable<Claim>
@{ ViewData["Title"] = "Permissions List"; }

<div class="p-8">
    <nav class="mb-6 flex items-center text-sm text-gray-500">
        <a asp-controller="Role" asp-action="Index" class="hover:text-indigo-600 transition-colors">Role Management</a>
        <span class="mx-2">/</span>
        <span class="font-bold text-gray-800">Permissions: @ViewBag.RoleName</span>
    </nav>

    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 mb-8">
        <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Add New Permission</h3>
        <form asp-action="Create" method="post" class="flex flex-wrap gap-4 items-end">
            <input type="hidden" name="roleId" value="@ViewBag.RoleId" />
            <div class="flex-1 min-w-[240px]">
                <label class="block text-xs font-bold text-gray-700 mb-1">Claim Type</label>
                <input name="claimType" type="text" placeholder="e.g. Permission" class="w-full px-4 py-2 border rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none" required />
            </div>
            <div class="flex-1 min-w-[240px]">
                <label class="block text-xs font-bold text-gray-700 mb-1">Claim Value</label>
                <input name="claimValue" type="text" placeholder="e.g. EditDevice" class="w-full px-4 py-2 border rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none" required />
            </div>
            <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2 rounded-lg font-bold text-sm shadow-md transition-all">Add</button>
        </form>
    </div>

    <div class="bg-white shadow rounded-xl overflow-hidden border border-gray-100">
        <table class="min-w-full">
            <thead class="bg-gray-50 border-b border-gray-200 text-xs font-bold text-gray-500 uppercase">
                <tr>
                    <th class="px-6 py-4 text-left">Type</th>
                    <th class="px-6 py-4 text-left">Value</th>
                    <th class="px-6 py-4 text-center">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 text-sm">
                @if (!Model.Any()) {
                    <tr><td colspan="3" class="px-6 py-10 text-center text-gray-400 italic">No specific permissions assigned.</td></tr>
                }
                @foreach (var claim in Model) {
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-6 py-4 font-mono text-xs text-gray-500">@claim.Type</td>
                        <td class="px-6 py-4 font-semibold text-indigo-600">@claim.Value</td>
                        <td class="px-6 py-4">
                            <div class="flex justify-center gap-4">
                                <a asp-action="Edit" asp-route-roleId="@ViewBag.RoleId" asp-route-claimType="@claim.Type" asp-route-claimValue="@claim.Value" class="text-blue-500 hover:text-blue-700 font-bold">Edit</a>
                                <form asp-action="Delete" method="post" onsubmit="return confirm('Remove this permission?')">
                                    <input type="hidden" name="roleId" value="@ViewBag.RoleId" />
                                    <input type="hidden" name="claimType" value="@claim.Type" />
                                    <input type="hidden" name="claimValue" value="@claim.Value" />
                                    <button type="submit" class="text-red-500 hover:text-red-700 font-bold">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
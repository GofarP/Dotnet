@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Vending IOT Dashboard</title>
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
</head>

<body class="bg-slate-50 font-sans antialiased text-gray-900 overflow-hidden">
    <div class="flex h-screen w-full">

        <div id="sidebar-overlay"
             class="fixed inset-0 bg-slate-900/10 backdrop-blur-sm z-40 hidden md:hidden transition-opacity cursor-pointer">
        </div>

        <aside id="sidebar"
               class="fixed inset-y-0 left-0 z-50 w-64 bg-slate-900 text-slate-300 transition-all duration-300 ease-in-out transform -translate-x-full md:relative md:translate-x-0 flex flex-col shadow-2xl md:shadow-none">
            
            <div class="flex items-center justify-center h-16 border-b border-slate-800 flex-shrink-0">
                <span class="text-xl font-bold text-white tracking-tight">
                    Vending <span class="text-indigo-500">IOT</span>
                </span>
            </div>

            <nav class="flex-1 overflow-y-auto py-4 space-y-1">
    
                <div class="px-6 text-sm font-normal text-slate-400 mt-2 mb-1 tracking-wide">
                    General
                </div>

                <a asp-controller="Home" asp-action="Index"
                       class="flex items-center gap-3 px-6 py-3 transition-colors @(currentController == "Home" ? "bg-blue-500 text-white" : "text-slate-400 hover:text-white hover:bg-slate-800")">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                    </svg>
                    <span class="font-medium text-sm">Dashboard</span>
                </a>

                 <div class="px-6 text-sm font-normal text-slate-400 mt-2 mb-1 tracking-wide">
                    Role and Claims
                </div>

                  <a asp-controller="Role" asp-action="Index"
                       class="flex items-center gap-3 px-6 py-3 transition-colors @(currentController == "Role" ? "bg-blue-500 text-white" : "text-slate-400 hover:text-white hover:bg-slate-800")">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                    </svg>
                    <span class="font-medium text-sm">Role</span>
                 </a>

                 <a asp-controller="Permission" asp-action="Index"
                class="flex items-center gap-3 px-6 py-3 transition-colors @(currentController == "Permission" ? "bg-blue-500 text-white" : "text-slate-400 hover:text-white hover:bg-slate-800")">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                            d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
                    </svg>
                    <span class="font-medium text-sm">Permissions</span>
                </a>



                <div class="px-6 text-sm font-normal text-slate-400 mt-2 mb-1 tracking-wide">
                    Account
                </div>

                <a asp-controller='Employee' asp-action="Index" 
                    class="flex items-center gap-3 px-6 py-3 transition-colors @(currentController == "Employee" ? "bg-blue-500 text-white" : "text-slate-400 hover:text-white hover:bg-slate-800")">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                    <span class="font-medium text-sm">Employee</span>
                </a>
                
                @if (User.HasClaim("Permission", "show.department"))
                {
                       <div class="px-6 text-sm font-normal text-slate-400 mt-2 mb-1 tracking-wide">
                            Department
                        </div>

                        <a asp-controller="Department" asp-action="Index"
                            class="flex items-center gap-3 px-6 py-3 transition-colors @(currentController == "Department" ? "bg-blue-500 text-white" : "text-slate-400 hover:text-white hover:bg-slate-800")">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M10 3h4v4h-4zM12 7v5M6 12h12M8 12v4M6 16h4v4h-4zM16 12v4M14 16h4v4h-4z" />
                            </svg>
                            <span class="font-medium text-sm">Department</span>
                        </a>
                }
             


                <div class="px-6 text-sm font-normal text-slate-400 mt-2 mb-1 tracking-wide">
                    IOT Stuff
                </div>
                <a asp-controller="Machine" asp-action="Index"
                       class="flex items-center gap-3 px-6 py-3 text-slate-400 hover:text-white hover:bg-slate-800 transition-colors @(currentController == "Machine" ? "bg-blue-500 text-white" : "text-slate-400 hover:text-white hover:bg-slate-800")">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                    </svg>
                    <span class="font-medium text-sm">Data Mesin</span>
                </a>

                <div class="px-6 text-sm font-normal text-slate-400 mt-2 mb-1 tracking-wide">
                    Product
                </div>
                <a asp-controller="Product" asp-action="Index"
                class="flex items-center gap-3 px-6 py-3 transition-colors @(currentController == "Product" ? "bg-blue-500 text-white" : "text-slate-400 hover:text-white hover:bg-slate-800")">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                            d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                    </svg>
                    <span class="font-medium text-sm">Product</span>
                </a>
    
            </nav>
            
            <div class="p-4 border-t border-slate-800 text-xs text-center text-slate-500 flex-shrink-0">
                &copy; 2026 Vending IOT
            </div>
        </aside>

        <div class="flex flex-col flex-1 min-w-0 overflow-hidden transition-all duration-300">
            
            <header
                class="bg-white shadow-sm border-b border-slate-200 h-16 flex-shrink-0 flex items-center justify-between px-4 sm:px-6 z-10">
                
                <button id="mobile-menu-button" type="button"
                        class="inline-flex items-center justify-center p-2 rounded-xl text-slate-500 hover:text-indigo-600 hover:bg-indigo-50 focus:outline-none transition-colors cursor-pointer -ml-2">
                    <span class="sr-only">Toggle Sidebar</span>
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                </button>

                <div class="flex items-center gap-4">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <div class="flex items-center gap-4 border-l pl-4 md:pl-6 border-slate-200">

                            <span class="text-xs sm:text-sm text-slate-500 font-medium">
                                Halo, <span class="text-slate-900 font-bold">@UserManager.GetUserName(User)</span>
                            </span>
                            
                            <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post">
                                <button type="submit"
                                        class="px-4 py-2 text-sm font-bold text-white bg-red-500 rounded-lg hover:bg-red-600 transition-all shadow hover:shadow-md active:scale-95 cursor-pointer">
                                    Logout
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <a asp-area="Identity" asp-page="/Account/Login"
                               class="px-5 py-2 text-sm font-bold text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 transition-all shadow hover:shadow-md active:scale-95">
                            Login
                        </a>
                    }
                </div>
            </header>

            <main class="flex-1 overflow-y-auto p-4 sm:p-6 lg:p-8 bg-slate-50">
                @RenderBody()
            </main>
        </div>
    </div>

    <div id="toast-container" class="fixed top-20 right-8 z-50 flex flex-col gap-3">
        @if (TempData["SuccessMessage"] != null)
        {
            <div
                class="toast-alert flex items-center w-full max-w-xs p-4 text-slate-600 bg-white border-l-4 border-blue-500 rounded-lg shadow-lg transition-opacity duration-500">
                <div
                    class="inline-flex items-center justify-center flex-shrink-0 w-8 h-8 text-blue-500 bg-blue-50 rounded-lg">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                </div>
                <div class="ml-3 text-sm font-medium">@TempData["SuccessMessage"]</div>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div
                class="toast-alert flex items-center w-full max-w-xs p-4 text-slate-600 bg-white border-l-4 border-red-500 rounded-lg shadow-lg transition-opacity duration-500">
                <div
                    class="inline-flex items-center justify-center flex-shrink-0 w-8 h-8 text-red-500 bg-red-50 rounded-lg">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12">
                        </path>
                    </svg>
                </div>
                <div class="ml-3 text-sm font-medium">@TempData["ErrorMessage"]</div>
            </div>
        }
    </div>

    <script>
            document.addEventListener('DOMContentLoaded', function () {
                const sidebar = document.getElementById('sidebar');
                const overlay = document.getElementById('sidebar-overlay');
                const btn = document.getElementById('mobile-menu-button');
                const toasts = document.querySelectorAll('.toast-alert');

                if (toasts.length > 0) {
                    setTimeout(() => {
                        toasts.forEach(toast => {
                            toast.classList.add('opacity-0');
                            setTimeout(() => toast.remove(), 500);
                        });
                    }, 3500);
                }

                function toggleSidebar() {
                    // Cek apakah lebar layar >= 768px (Desktop/MacBook)
                    if (window.innerWidth >= 768) {
                        // Tarik sidebar ke luar layar menggunakan margin negatif
                        sidebar.classList.toggle('md:-ml-64');
                    } else {
                        // Geser sidebar & munculkan latar gelap untuk Mobile
                        sidebar.classList.toggle('-translate-x-full');
                        overlay.classList.toggle('hidden');
                    }
                }

                // Tombol hamburger diklik
                btn.addEventListener('click', toggleSidebar);

                // Layar gelap diklik (Hanya di Mobile)
                overlay.addEventListener('click', function () {
                    sidebar.classList.add('-translate-x-full');
                    overlay.classList.add('hidden');
                });
            });
    </script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"
            integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
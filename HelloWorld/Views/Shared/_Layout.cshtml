@using Microsoft.AspNetCore.Identity
@* Pakai IdentityUser bawaan, tidak perlu buat file model sendiri *@
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Vending IOT</title>
    @* Pastikan path ini sesuai dengan file CSS Tailwind kamu *@
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
</head>

<body class="bg-slate-50 font-sans antialiased text-gray-900">

    <header>
        <nav class="bg-white shadow-sm border-b border-slate-100 px-6 sm:px-8 py-4">
            <div class="flex items-center justify-between flex-wrap max-w-7xl mx-auto">
                <div class="text-xl font-bold text-indigo-600 tracking-tight flex-shrink-0">
                    Vending <span class="text-slate-900">IOT</span>
                </div>

                <button id="mobile-menu-button" type="button"
                        class="md:hidden inline-flex items-center justify-center p-2 rounded-xl text-slate-500 hover:text-indigo-600 hover:bg-indigo-50 focus:outline-none transition-colors cursor-pointer">
                    <span class="sr-only">Buka menu utama</span>
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                </button>

                <div id="mobile-menu"
                     class="hidden w-full md:flex md:w-auto md:items-center mt-4 md:mt-0 transition-all">
                    <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-8">
                
                        <a href="/"
                               class="block px-2 py-2 md:p-0 text-sm font-semibold text-slate-600 hover:text-indigo-600 transition-colors">
                            Dashboard
                        </a>

                        @if (SignInManager.IsSignedIn(User))
                        {
                            <div
                                class="flex flex-col md:flex-row md:items-center gap-4 md:border-l md:pl-8 border-slate-200 pt-4 md:pt-0 border-t md:border-t-0 mt-2 md:mt-0">
                                <span class="px-2 md:p-0 text-sm text-slate-500 font-medium">
                                    Halo, <span class="text-slate-900 font-bold">@UserManager.GetUserName(User)</span>
                                </span>
                        
                                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post"
                                      class="w-full md:w-auto">
                                    <button type="submit"
                                            class="w-full md:w-auto px-4 py-2.5 md:py-2 text-sm font-bold text-white bg-red-500 rounded-xl hover:bg-red-600 transition-all shadow-md active:scale-95 cursor-pointer">
                                        Logout
                                    </button>
                                </form>
                            </div>
                        }
                        else
                        {
                            <a asp-area="Identity" asp-page="/Account/Login"
                                   class="block text-center px-5 py-2.5 md:py-2 mt-2 md:mt-0 text-sm font-bold text-white bg-indigo-600 rounded-xl hover:bg-indigo-700 transition-all shadow-md active:scale-95">
                                Login
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mx-auto px-4 py-8">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script>
            document.addEventListener('DOMContentLoaded', function () {
                const btn = document.getElementById('mobile-menu-button');
                const menu = document.getElementById('mobile-menu');

                btn.addEventListener('click', () => {
                    menu.classList.toggle('hidden');
                });
            }); 
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>